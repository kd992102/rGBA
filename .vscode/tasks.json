{
    "tasks": [
        {
            "type": "shell",
            "label": "build",
            "command": "C:\\msys64\\mingw32\\bin\\make.exe",
            "args": [
                "-f",
                "Makefile.new",
                "all"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "偵錯工具產生的工作。"
        },
        {
            "type": "cppbuild",
            "label": "build-legacy",
            "command": "C:\\msys64\\mingw32\\bin\\gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-lSDL2",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "編譯器: C:\\msys64\\mingw32\\bin"
        }
    ],
    "version": "2.0.0"
